{
  "name": "proctorx",
  "version": "1.0.0",
  "description": "AI ProctorX — Exam Proctoring Platform",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.proctorx.app",
    "productName": "ProctorX",
    "copyright": "ProctorX",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": ["nsis"],
      "icon": "static/icons/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "static/icons/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "static/icons/icon.png"
    },
    "extraResources": [
      { "from": ".", "to": "app", "filter": ["**/*", "!node_modules", "!dist-electron", "!.git", "!venv"] }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
